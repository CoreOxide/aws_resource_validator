# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg

# Build artefacts
build/
dist/
.eggs/

# Lock files — not committed. See scripts/release/README for why:
# sub-packages release in lock-step with main, and Poetry can't lock
# the circular ``main <-> aws-resource-validator-<svc>`` constraint
# across a version bump.
poetry.lock

# Virtualenvs
.venv/
venv/
env/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE / editor metadata
.idea/
.vscode/
.idx/
*.swp
*.swo

# OS metadata
.DS_Store
Thumbs.db

# Local scratch
*.tmp
/tmp_*
